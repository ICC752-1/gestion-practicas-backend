# ------ JWT ------
# Generar JWT_SECRET_KEY con: openssl rand -hex 32
JWT_SECRET_KEY=<token-random>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ------ Database ------
POSTGRES_USER=<usuario>
POSTGRES_PASSWORD=<contraseña>
POSTGRES_DB=internship_db
POSTGRES_PORT=5432
POSTGRES_HOST=db

# ------ Logging ------
LOG_DIR=logs
LOG_FILE_NAME=gestion_practicas.jsonl
LOG_ERROR_FILE_NAME=gestion_practicas_errors.jsonl
LOG_LEVEL=INFO
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# ------ Documents ------
# En produccion VPS usar una ruta persistente montada al contenedor, por ejemplo
# /app/storage/documents respaldada por un volumen Docker o bind mount privado.
DOCUMENT_STORAGE_DIR=storage/documents
PRESENTATION_LETTER_STORAGE_DIR=storage/presentation_letters
PRESENTATION_LETTER_DOCX_TEMPLATE_PATH=app/core/assets/presentation_letter_template.docx
LIBREOFFICE_BINARY=libreoffice
LIBREOFFICE_TIMEOUT_SECONDS=60
DOCUMENT_MAX_BYTES=10485760
DOCUMENT_ALLOWED_EXTENSIONS=pdf,docx,jpg,png,zip
# 0 conserva documentos indefinidamente hasta que exista una politica formal.
DOCUMENT_RETENTION_DAYS=0

# ---- Prácticas ----
# Ventana en horas para que el estudiante propietario corrija o anule una
# solicitud pendiente antes de cualquier acción administrativa.
STUDENT_CORRECTION_WINDOW_HOURS=24

# ------ CORS ------
# Lista separada por comas. Ajustar en producción al origen real del frontend.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ------ Frontend ------
# Base publica usada para construir enlaces enviados por correo.
FRONTEND_BASE_URL=http://localhost:5173
USER_ACTIVATION_TOKEN_EXPIRE_HOURS=24

# ------ Google OAuth ------
# El backend define defaults locales para callback, dominios y URLs frontend.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Override opcional si el cliente OAuth local usa otro origen.
# GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
# GOOGLE_ALLOWED_DOMAINS=ufromail.cl,ufrontera.cl
# GOOGLE_FRONTEND_SUCCESS_URL=http://localhost:5173/auth/callback
# GOOGLE_FRONTEND_ERROR_URL=http://localhost:5173/auth/callback
# GOOGLE_COOKIE_SECURE=False
# REFRESH_TOKEN_COOKIE_NAME=refresh_token
# REFRESH_TOKEN_COOKIE_SECURE=False

# ---- Notificaciones ----
# Valores posibles: simulated | real
# En modo "simulated" las notificaciones se persisten sin envío SMTP.
# En modo "real" se requiere configuración MAIL_* completa.
NOTIFICATION_MODE=simulated

# ---- email ----
MAIL_USERNAME=gestor.practica@gmail.com
MAIL_PASSWORD=<app-password>
MAIL_FROM=gestor.practica@gmail.com
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_STARTTLS=True
MAIL_SSL_TLS=False
