# ------ JWT ------
# Generar JWT_SECRET_KEY con: openssl rand -hex 32
JWT_SECRET_KEY=<token-random>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ------ OAuth Google ------
GOOGLE_OAUTH_CLIENT_ID=<google-client-id>
GOOGLE_OAUTH_CLIENT_SECRET=<google-client-secret>
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/oauth/google/callback
GOOGLE_OAUTH_ALLOWED_DOMAIN=ufromail.cl
FRONTEND_AUTH_SUCCESS_URL=http://localhost:5173/dashboard

# ------ Auth Cookies ------
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_DOMAIN=

# ------ Database ------
POSTGRES_USER=<usuario>
POSTGRES_PASSWORD=<contraseña>
POSTGRES_DB=internship_db
POSTGRES_PORT=5432
POSTGRES_HOST=db

# ------ Logging ------
LOG_DIR=logs
LOG_FILE_NAME=gestion_practicas.jsonl
LOG_ERROR_FILE_NAME=gestion_practicas_errors.jsonl
LOG_LEVEL=INFO
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5


