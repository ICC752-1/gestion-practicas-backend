# ------ JWT ------
# Generar JWT_SECRET_KEY con: openssl rand -hex 32
JWT_SECRET_KEY=<token-random>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ------ OAuth Google ------
GOOGLE_OAUTH_CLIENT_ID=<google-client-id>
GOOGLE_OAUTH_CLIENT_SECRET=<google-client-secret>
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/oauth/google/callback
GOOGLE_OAUTH_ALLOWED_DOMAIN=ufromail.cl
FRONTEND_AUTH_SUCCESS_URL=http://localhost:5173/dashboard

# ------ Auth Cookies ------
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_DOMAIN=

# ------ Database ------
POSTGRES_USER=<usuario>
POSTGRES_PASSWORD=<contraseña>
POSTGRES_DB=internship_db
POSTGRES_PORT=5432
POSTGRES_HOST=db

# ------ Logging ------
LOG_DIR=logs
LOG_FILE_NAME=gestion_practicas.jsonl
LOG_ERROR_FILE_NAME=gestion_practicas_errors.jsonl
LOG_LEVEL=INFO
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# ------ CORS ------
# Lista separada por comas. Ajustar en producción al origen real del frontend.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---- Notificaciones ----
# Valores posibles: simulated | real
# En modo "simulated" las notificaciones se persisten sin envío SMTP.
# En modo "real" se requiere configuración MAIL_* completa.
NOTIFICATION_MODE=simulated

# ---- email ----
MAIL_USERNAME=gestor.practica@gmail.com
MAIL_PASSWORD=<app-password>
MAIL_FROM=gestor.practica@gmail.com
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_STARTTLS=True
MAIL_SSL_TLS=False
