# ------ JWT ------
# Generar JWT_SECRET_KEY con: openssl rand -hex 32
JWT_SECRET_KEY=<token-random>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ------ Database ------
POSTGRES_USER=<usuario>
POSTGRES_PASSWORD=<contraseña>
POSTGRES_DB=internship_db
POSTGRES_PORT=5432
POSTGRES_HOST=db

# ------ Logging ------
LOG_DIR=logs
LOG_FILE_NAME=gestion_practicas.jsonl
LOG_ERROR_FILE_NAME=gestion_practicas_errors.jsonl
LOG_LEVEL=INFO
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# ------ Documents ------
DOCUMENT_STORAGE_DIR=storage/documents
DOCUMENT_MAX_BYTES=10485760
DOCUMENT_ALLOWED_EXTENSIONS=pdf,docx,jpg,png,zip

# ------ CORS ------
# Lista separada por comas. Ajustar en producción al origen real del frontend.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ------ Google OAuth ------
# El backend define defaults locales para callback, dominios y URLs frontend.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Override opcional si el cliente OAuth local usa otro origen.
# GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
# GOOGLE_ALLOWED_DOMAINS=ufromail.cl,ufrontera.cl
# GOOGLE_FRONTEND_SUCCESS_URL=http://localhost:5173/auth/callback
# GOOGLE_FRONTEND_ERROR_URL=http://localhost:5173/auth/callback
# GOOGLE_COOKIE_SECURE=False

# ---- Notificaciones ----
# Valores posibles: simulated | real
# En modo "simulated" las notificaciones se persisten sin envío SMTP.
# En modo "real" se requiere configuración MAIL_* completa.
NOTIFICATION_MODE=simulated

# ------ Google OAuth ------
# Variables principales para el cliente web de Google en GCP.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
GOOGLE_ALLOWED_DOMAINS=ufromail.cl,ufrontera.cl
GOOGLE_FRONTEND_SUCCESS_URL=http://localhost:5173/auth/callback
GOOGLE_FRONTEND_ERROR_URL=http://localhost:5173/auth/callback
GOOGLE_COOKIE_SECURE=False

# ---- email ----
MAIL_USERNAME=gestor.practica@gmail.com
MAIL_PASSWORD=<app-password>
MAIL_FROM=gestor.practica@gmail.com
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_STARTTLS=True
MAIL_SSL_TLS=False
