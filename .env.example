# ------ JWT ------
# Generar JWT_SECRET_KEY con: openssl rand -hex 32
JWT_SECRET_KEY=<token-random>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ------ Database ------
POSTGRES_USER=<usuario>
POSTGRES_PASSWORD=<contraseña>
POSTGRES_DB=internship_db
POSTGRES_PORT=5432
POSTGRES_HOST=db

# ------ Logging ------
LOG_DIR=logs
LOG_FILE_NAME=gestion_practicas.jsonl
LOG_ERROR_FILE_NAME=gestion_practicas_errors.jsonl
LOG_LEVEL=INFO
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5


# ---- email ----
MAIL_USERNAME= <ejemplo@gmail.com>
MAIL_PASSWORD=<contraseña_de_aplicacion>
MAIL_FROM=<tu_correo@gmail.com>
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_STARTTLS=True
MAIL_SSL_TLS=False